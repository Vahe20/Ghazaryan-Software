NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Auth security
BCRYPT_SALT_ROUNDS=10
AUTH_MAX_ATTEMPTS=5
AUTH_BLOCK_MINUTES=15

# Sessions / cookies
SESSION_EXPIRES_DAYS=30
COOKIE_SAME_SITE=strict
# COOKIE_SECURE defaults to true in production; set explicitly to override
# COOKIE_SECURE=false

# External services
FRONTEND_URL=
BACKEND_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Redis
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
